{
  "name": "lyricdisplay-ndi",
  "version": "1.0.5",
  "description": "NDI™ companion for LyricDisplay — broadcasts output pages over NDI",
  "author": {
    "name": "Peter Alakembi",
    "email": "alakembipeter30@gmail.com"
  },
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start": "electron src/main.js",
    "build": "node build.js",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "grandi": "^1.3.0"
  },
  "devDependencies": {
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.lyricdisplay.ndi",
    "productName": "LyricDisplay NDI",
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/grandi/**",
      "node_modules/@grandi/**"
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico",
      "artifactName": "lyricdisplay-ndi-win.${ext}"
    },
    "mac": {
      "target": "zip",
      "icon": "public/favicon.icns",
      "artifactName": "lyricdisplay-ndi-mac-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.png",
      "artifactName": "lyricdisplay-ndi-linux.${ext}"
    }
  }
}
